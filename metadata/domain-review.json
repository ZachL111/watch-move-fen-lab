{
  "repo": "watch-move-fen-lab",
  "language": "Elixir",
  "category": "Chess and game engines",
  "goal": "Build an Elixir toolkit that studies fen behavior through negative fixtures, with human-readable error snapshots and no network dependency.",
  "review_model": {
    "terms": [
      "position pressure",
      "move ordering",
      "search width",
      "endgame risk"
    ],
    "lanes": [
      "ship",
      "watch",
      "hold"
    ],
    "score": "signal * 2 + slack + confidence - drag * 3",
    "purpose": "surface the domain-specific cases that need the most careful review"
  },
  "cases": [
